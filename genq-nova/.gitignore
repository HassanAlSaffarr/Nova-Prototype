# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
.pytest_cache/

# Agent data (local only, can be large)
agent/data/imagery/
# Footprints: ignore the raw MS source, but track the slimmed served artifact
# (the web buildings base layer depends on it; regenerate via scripts/slim_footprints.py)
agent/data/footprints/*
!agent/data/footprints/karrada.min.geojson
agent/data/rasters/
agent/data/*.db
# Autonomous-loop runtime state (regenerate: python -m nova.loop --once)
agent/data/detections_live.geojson
# API server log (background process)
agent/data/api.out

# Agent credentials
agent/credentials/

# Node
node_modules/
.next/
out/

# Env
.env
.env.local

# Secrets
*.pem
*-service-account*.json

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
.claude/

# Cached Esri thumbnails (regenerable)
agent/data/cache/

# Local script scratch (temp stores, logs)
scripts/_tmp_loop/
scripts/*.log
